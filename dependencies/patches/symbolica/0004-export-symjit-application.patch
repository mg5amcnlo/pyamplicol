+    /// Export the exact serialized SymJIT application selected for complex f64 evaluation.
+    ///
+    /// The evaluator must be configured for JIT compilation and its target-specific complex
+    /// payload must already have been compiled by calling `evaluate_complex`. Applications that
+    /// use external functions are rejected because those definitions are not self-contained in
+    /// the serialized SymJIT application.
+    #[gen_stub(override_return_type(
+        type_repr = "tuple[bytes, typing.Literal['complex-f64', 'complex-f64x2']]",
+        imports = ("typing")
+    ))]
+    fn export_symjit_f64_application<'py>(
+        &self,
+        py: Python<'py>,
+    ) -> PyResult<(Bound<'py, PyBytes>, &'static str)> {
+        if !self.jit_compile {
+            return Err(exceptions::PyRuntimeError::new_err(
+                "Cannot export a SymJIT f64 application because this evaluator is not configured for JIT compilation.",
+            ));
+        }
+
+        #[cfg(target_arch = "aarch64")]
+        let (evaluator, layout) = (
+            self.jit_complex_native2.as_ref().ok_or_else(|| {
+                exceptions::PyRuntimeError::new_err(
+                    "Cannot export a SymJIT f64 application because no complex JIT payload has been compiled for this target. Call evaluate_complex() once before exporting it.",
+                )
+            })?,
+            "complex-f64x2",
+        );
+
+        #[cfg(not(target_arch = "aarch64"))]
+        let (evaluator, layout) = (
+            self.jit_complex.as_ref().ok_or_else(|| {
+                exceptions::PyRuntimeError::new_err(
+                    "Cannot export a SymJIT f64 application because no complex JIT payload has been compiled for this target. Call evaluate_complex() once before exporting it.",
+                )
+            })?,
+            "complex-f64",
+        );
+
+        if evaluator.has_external_functions() {
+            return Err(exceptions::PyRuntimeError::new_err(
+                "Cannot export a self-contained SymJIT f64 application because the selected JIT payload uses external functions.",
+            ));
+        }
+
+        Ok((
+            PyBytes::new(py, evaluator.symjit_application_bytes()),
+            layout,
+        ))
+    }
