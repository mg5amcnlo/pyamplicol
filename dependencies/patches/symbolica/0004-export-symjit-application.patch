+#[test]
+fn jit_application_bytes_are_exposed_without_external_functions() {
+    let params = vec![parse!("x"), parse!("y")];
+    let evaluator = parse!("x + y")
+        .evaluator(&params)
+        .horner_iterations(0)
+        .build()
+        .unwrap();
+    let jit = evaluator
+        .jit_compile::<Complex<f64>>(JITCompilationSettings::default())
+        .unwrap();
+
+    assert!(!jit.symjit_application_bytes().is_empty());
+    assert!(!jit.has_external_functions());
+}
