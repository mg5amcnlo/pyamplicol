+impl EvaluationDomain for Complex<wide::f64x2> {
+    const FIXED_PRECISION: Option<u32> = Some(53);
+
+    fn try_from_complex_float(f: Complex<Float>) -> Result<Self, String> {
+        let re = f.re.to_f64();
+        let im = f.im.to_f64();
+        Ok(Complex::new(
+            wide::f64x2::new([re; 2]),
+            wide::f64x2::new([im; 2]),
+        ))
+    }
+
+    fn resolve_function(
+        tags: &[AtomView],
+        info: &EvaluationInfo,
+    ) -> Option<Box<dyn ExternalFunction<Self>>> {
+        if let Some(f) = info.get_evaluator::<Complex<wide::f64x2>>(tags) {
+            return Some(f);
+        }
+
+        Complex::<f64>::resolve_function(tags, info).map(|f| {
+            Box::new(move |args: &[Complex<wide::f64x2>]| {
+                let mut buffer = smallvec::SmallVec::<[Complex<f64>; 4]>::from_iter(
+                    std::iter::repeat_n(Complex::new(0.0, 0.0), args.len()),
+                );
+                let mut res = [Complex::new(0.0, 0.0); 2];
+
+                for lane in 0..2 {
+                    for (dest, value) in buffer.iter_mut().zip(args) {
+                        *dest = Complex::new(value.re.as_array()[lane], value.im.as_array()[lane]);
+                    }
+                    res[lane] = f(&buffer);
+                }
+
+                Complex::new(
+                    wide::f64x2::new(res.map(|x| x.re)),
+                    wide::f64x2::new(res.map(|x| x.im)),
+                )
+            }) as Box<dyn ExternalFunction<Complex<wide::f64x2>>>
+        })
+    }
+}
