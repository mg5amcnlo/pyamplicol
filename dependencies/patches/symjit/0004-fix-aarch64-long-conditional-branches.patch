diff --git a/rust/arm/mod.rs b/rust/arm/mod.rs
--- a/rust/arm/mod.rs
+++ b/rust/arm/mod.rs
@@ -57,6 +57,13 @@ fn emit(a: &mut Assembler, w: u32) {
     a.append_word(w);
 }
 
+fn branch_eq_long(a: &mut Assembler, label: &str) {
+    let skip = a.create_label();
+    a.jump(&skip, 0, |offset, _| arm! {b.ne label(offset)});
+    a.jump(label, 0, |offset, _| arm! {b label(offset)});
+    a.set_label(&skip);
+}
+
 fn add_x_from_sp(a: &mut Assembler, dst: u8, offset: u32) {
     let low = offset & 0x0fff;
     let high = offset >> 12;
@@ -232,4 +239,17 @@ mod tests {
         add_stack(&mut add, size);
         assert_eq!(add.bytes().len(), 3 * 4);
     }
+
+    #[test]
+    fn conditional_branch_supports_targets_beyond_one_megabyte() {
+        let mut assembler = Assembler::new();
+        branch_eq_long(&mut assembler, "target");
+        for _ in 0..(1_048_576 / 4 + 1) {
+            emit(&mut assembler, arm! {nop});
+        }
+        assembler.set_label("target");
+
+        assembler.apply_jumps();
+        assert!(assembler.bytes().len() > 1_048_576);
+    }
 }
