+    fn direct_application_rejects_nonportable_optimization_level() {
+        let error = DirectApplication::new(
+            source_application(3),
+            metadata(DirectDestinationOperation::Add),
+        )
+        .err()
+        .expect("O3 must be rejected");
+        assert!(error.to_string().contains("O2 source"));
+    }
