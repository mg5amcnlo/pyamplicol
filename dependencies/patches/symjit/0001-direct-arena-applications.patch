+        source.save(&mut source_bytes).unwrap();
+        let direct = DirectApplication::from_source_storage(
+            &mut source_bytes.as_slice(),
+            &Config::default(),
+            metadata(DirectDestinationOperation::Add),
+        )
+        .unwrap();
+        assert_eq!(
+            direct.metadata(),
+            &metadata(DirectDestinationOperation::Add)
+        );
+    }
