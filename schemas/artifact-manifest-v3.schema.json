{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pyamplicol.org/schemas/artifact-manifest-v3.schema.json",
  "title": "pyAmpliCol process artifact manifest v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "artifact_id",
    "created_utc",
    "producer",
    "model",
    "configuration",
    "processes",
    "runtime",
    "payloads",
    "dependencies"
  ],
  "properties": {
    "schema_version": {
      "const": 3
    },
    "kind": {
      "enum": [
        "pyamplicol-process",
        "pyamplicol-process-set"
      ]
    },
    "artifact_id": {
      "$ref": "#/$defs/sha256"
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "$ref": "#/$defs/producer"
    },
    "model": {
      "$ref": "#/$defs/model"
    },
    "configuration": {
      "$ref": "#/$defs/configuration"
    },
    "processes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/process"
      }
    },
    "default_process_id": {
      "oneOf": [
        {
          "$ref": "#/$defs/public_id"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "runtime": {
      "$ref": "#/$defs/runtime"
    },
    "payloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/payload"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "extensions": {
      "type": "object",
      "default": {}
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "git_revision": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "public_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:+,~-]*$"
    },
    "runtime_capability": {
      "enum": [
        "symjit.application.complex-f64.v1",
        "symbolica.legacy-jit-container.complex-f64.v1",
        "symbolica.compiled-cpp.complex-f64.v1",
        "symbolica.compiled-asm.complex-f64.v1"
      ]
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "version_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_api",
        "toml",
        "compiled_model",
        "process_artifact",
        "runtime_physics",
        "symbolica_serialization",
        "c_abi"
      ],
      "properties": {
        "python_api": {
          "type": "integer",
          "minimum": 1
        },
        "toml": {
          "type": "integer",
          "minimum": 1
        },
        "compiled_model": {
          "type": "integer",
          "minimum": 1
        },
        "process_artifact": {
          "const": 3
        },
        "runtime_physics": {
          "const": 1
        },
        "symbolica_serialization": {
          "type": "string",
          "minLength": 1
        },
        "c_abi": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "triple",
        "cpu_features"
      ],
      "properties": {
        "triple": {
          "type": "string",
          "minLength": 1
        },
        "cpu_features": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "distribution",
        "version",
        "versions",
        "target"
      ],
      "properties": {
        "distribution": {
          "const": "pyamplicol"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "versions": {
          "$ref": "#/$defs/version_set"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "git_revision": {
          "oneOf": [
            {
              "$ref": "#/$defs/git_revision"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source_kind",
        "content_sha256",
        "compiled_schema_version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "enum": [
            "built-in-sm",
            "ufo",
            "ufo-json",
            "compiled-model"
          ]
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "compiled_schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "restriction": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toml_schema_version",
        "requested_path",
        "effective_path",
        "adjustments"
      ],
      "properties": {
        "toml_schema_version": {
          "const": 1
        },
        "requested_path": {
          "$ref": "#/$defs/relative_path"
        },
        "effective_path": {
          "$ref": "#/$defs/relative_path"
        },
        "adjustments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "reason"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "expression",
        "color_accuracy",
        "external_pdgs",
        "physics_path",
        "required_runtime_capabilities",
        "aliases"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/public_id"
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "color_accuracy": {
          "enum": [
            "lc",
            "nlc",
            "full"
          ]
        },
        "external_pdgs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "integer"
          }
        },
        "physics_path": {
          "$ref": "#/$defs/relative_path"
        },
        "required_runtime_capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtime_capability"
          }
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "expression",
              "external_pdgs",
              "external_permutation"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/public_id"
              },
              "expression": {
                "type": "string",
                "minLength": 1
              },
              "external_pdgs": {
                "type": "array",
                "minItems": 3,
                "items": {
                  "type": "integer"
                }
              },
              "external_permutation": {
                "type": "array",
                "minItems": 3,
                "uniqueItems": true,
                "prefixItems": [
                  {
                    "const": 0
                  },
                  {
                    "const": 1
                  }
                ],
                "items": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "engine_version",
        "evaluator_manifest_path",
        "api_bundle_path",
        "required_runtime_capabilities"
      ],
      "properties": {
        "engine": {
          "const": "rusticol"
        },
        "engine_version": {
          "type": "string",
          "minLength": 1
        },
        "evaluator_manifest_path": {
          "$ref": "#/$defs/relative_path"
        },
        "api_bundle_path": {
          "oneOf": [
            {
              "$ref": "#/$defs/relative_path"
            },
            {
              "type": "null"
            }
          ]
        },
        "required_runtime_capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runtime_capability"
          }
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "executable": {
                "const": true
              }
            },
            "required": [
              "executable"
            ]
          },
          "then": {
            "properties": {
              "role": {
                "enum": [
                  "evaluator-state",
                  "api-source",
                  "api-build-file"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "role": {
                "const": "evaluator-state"
              }
            },
            "required": [
              "role"
            ]
          },
          "then": {
            "required": [
              "target"
            ]
          }
        }
      ],
      "required": [
        "path",
        "role",
        "media_type",
        "size_bytes",
        "sha256",
        "executable"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/relative_path"
        },
        "role": {
          "enum": [
            "configuration-requested",
            "configuration-effective",
            "compiled-model",
            "runtime-physics",
            "evaluator-manifest",
            "evaluator-state",
            "model-parameters",
            "validation-momenta",
            "api-source",
            "api-build-file",
            "sdk-metadata"
          ]
        },
        "media_type": {
          "type": "string",
          "minLength": 1
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "executable": {
          "type": "boolean"
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "process_id": {
          "$ref": "#/$defs/public_id"
        }
      }
    },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "source",
        "license"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "patch_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
