{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pyamplicol.org/schemas/reference-fixture-bundle-v1.schema.json",
  "title": "pyAmpliCol reference fixture bundle manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "files",
    "bundle_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "pyamplicol-reference-fixture-bundle"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.json$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "bundle_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
